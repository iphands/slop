default: all

# Format all crates.
fmt:
    cargo fmt --all

# Fail if any crate isn't formatted.
fmt-check:
    cargo fmt --all -- --check

# Lint everything; warnings are errors.
clippy:
    cargo clippy --all-targets --all-features -- -D warnings

# Run all tests.
test:
    cargo test --all-features

# Build all targets.
build:
    cargo build --all-targets

# Regenerate every nav-graph map cache at the default grid spacing (24u, GRID_SPACING).
# Override spacing: `just mapcache 12`. Narrow the map set: `just mapcache 24 'q2dm*'`.
# Release build — nav-graph generation is CPU-bound and far faster optimized.
# `--allow-failures`: cache every good map and report the rest (e.g. q2dm3 is a known-broken
# exception, tracked in context/plans/35_*) instead of letting one map sink the whole batch.
mapcache spacing="24" map="q2dm*":
    cargo run -p qbots --release -- generate-map-cache --map '{{map}}' --spacing {{spacing}} --allow-failures

# CI / pre-commit gate — fmt-check + clippy + test + build, all must pass.
all: fmt-check clippy test build
