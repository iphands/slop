# Build the workspace
build:
    cargo build

# Run tests
test:
    cargo test

# Run the ingestion CLI with test data
ingest-test:
    cargo run --bin ingest -- --dump-dir crates/lib_common/tests/fixtures --skip-qdrant

# Run the MCP server
server:
    cargo run --bin server

# Clean build artifacts
clean:
    cargo clean

# Check for warnings
check:
    cargo check --all-targets

# Format code
fmt:
    cargo fmt --all

# Lint code
clippy:
    cargo clippy --all-targets -- -D warnings

# Build release
release:
    cargo build --release
