#!/bin/bash
set -euo pipefail

# Build an optimized Quake II dedicated server image, in one of two flavors:
#
#     ./build q2repro    # Paril's Q2PRO / re-release fork (patched to also
#                        # accept vanilla/R1Q2/Q2PRO clients, e.g. yquake2)
#     ./build yquake     # Yamagi Quake II (native vanilla-protocol server)
#
# Each flavor is tagged  iphands/quake2:<flavor>  and  iphands/quake2:<flavor>-<ref>
# so both can coexist and be published independently. Then run ./publish.
#
# Bump the game version per flavor via env:
#     Q2REPRO_REF=nightly     ./build q2repro
#     YQUAKE2_REF=QUAKE2_8_60  ./build yquake
#
# ccache is persisted in a build cache mount, so a version bump only recompiles
# what actually changed. Patches live in patches/<flavor>/*.patch.

cd "$(dirname "$0")"

FLAVOR="${1:-}"
IMAGE="${IMAGE:-iphands/quake2}"
export DOCKER_BUILDKIT=1   # required for the ccache cache mount

case "$FLAVOR" in
    q2repro)
        DOCKERFILE="Dockerfile"
        REF="${Q2REPRO_REF:-rerelease-game}"
        BUILD_ARG="Q2REPRO_REF=${REF}"
        ;;
    yquake)
        DOCKERFILE="Dockerfile.yquake"
        REF="${YQUAKE2_REF:-QUAKE2_8_70}"
        BUILD_ARG="YQUAKE2_REF=${REF}"
        ;;
    *)
        echo "usage: ./build <q2repro|yquake>" >&2
        exit 2
        ;;
esac

# Sanitize the ref for use in a docker tag (branch refs may contain '/').
REFTAG="${REF//[^A-Za-z0-9_.-]/-}"

echo ">> building ${IMAGE}:${FLAVOR} (flavor=${FLAVOR}, ref=${REF})"

exec docker build -f "${DOCKERFILE}" \
    --build-arg "${BUILD_ARG}" \
    -t "${IMAGE}:${FLAVOR}" \
    -t "${IMAGE}:${FLAVOR}-${REFTAG}" \
    .
