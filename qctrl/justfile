# qctrl development commands

# node_modules env key: explicit QCTRL_ENV wins, else /etc/os-release ID (gentoo, fedora, ...).
# Each environment gets its own frontend/node_modules.<env> so native esbuild/rollup
# binaries are never shared across a bind-mounted host+container (avoids vite SIGSEGV).
nm_env := env_var_or_default("QCTRL_ENV", `. /etc/os-release 2>/dev/null; echo "${ID:-unknown}"`)

# NOTE: frontend tools run OUTSIDE just (e.g. an IDE) use whatever frontend/node_modules
# currently points at. Run `just fe-deps` after switching environments if you bypass just.

# NOTE: use node 22 (see frontend/.nvmrc). Gentoo's system node 24.14 SIGSEGVs inside
# vite — `npm ci`, `vite build` and `vitest` all die with no output. Node 22 runs all
# three clean. `just fe-node-check` tells you which node you're on.

# Ensure frontend/node_modules points at the per-env tree (installs on first use)
_nm:
    #!/usr/bin/env bash
    set -euo pipefail
    cd frontend
    env="{{nm_env}}"
    target="node_modules.$env"
    marker="$target/.qctrl-env"
    if [ -f "$marker" ]; then
        ln -sfn "$target" node_modules        # already built: just point at it
        exit 0
    fi
    echo ">> First-time node_modules setup for env '$env' -> $target"
    rm -rf node_modules                       # drop legacy real dir OR stale symlink (link only)
    npm ci                                    # installs a fresh REAL ./node_modules
    mv node_modules "$target"                 # stash under per-env name
    echo "$env" > "$marker"
    ln -sfn "$target" node_modules

# Warn when the active node will SIGSEGV inside vite (see note above)
fe-node-check:
    #!/usr/bin/env bash
    major="$(node -p 'process.versions.node.split(".")[0]')"
    if [ "$major" -ge 24 ]; then
        echo "WARNING: node v$(node -v | tr -d v) segfaults inside vite on this host."
        echo "         Use node 22 (frontend/.nvmrc): nvm use 22"
    else
        echo "node $(node -v) OK for vite"
    fi

# Point frontend/node_modules at the current env's tree (installs on first use)
fe-deps: _nm

# Frontend all-in-one checks
fe-all: _nm
    cd frontend && npm run build && npm run lint && npm run testall

# Backend all-in-one checks (fails on any warning)
be-all:
    cargo fmt --all
    cargo clippy --all-targets --all-features -- -D warnings
    RUSTFLAGS="-D warnings" cargo build --release

# Frontend tests
fe-test: _nm
    cd frontend && npm run testall

# Frontend build
fe-build: _nm
    cd frontend && npm run build

# Rust format all crates
be-fmt:
    cargo fmt --all

# Rust clippy with warnings as errors
be-clippy:
    cargo clippy --all-targets --all-features -- -D warnings

# Rust build with warnings as errors
be-build:
    RUSTFLAGS="-D warnings" cargo build --release

# Full CI check: fmt, clippy, build, frontend tests
ci: _nm
    cargo fmt --check
    cargo clippy --all-targets --all-features -- -D warnings
    RUSTFLAGS="-D warnings" cargo build --release
    cd frontend && npm run build

# Run backend
be-run:
    cargo run --bin qctrl-api --release -- --config-path config.yaml

# Run backend tests
be-test:
    cargo test --all-targets --all-features

# Run e2e tests
fe-e2e: _nm
    cd frontend && node e2e-test.js

# Format and check frontend
fe-lint: _nm
    cd frontend && npm run lint
