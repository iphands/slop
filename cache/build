#!/bin/bash
set -euo pipefail

# Build the container images.
#
#     ./build            # == ./build all
#     ./build proxy      # the nginx caching proxy
#     ./build stats      # the stats reader + dashboard
#
# Tags each moving  <image>:latest  plus an immutable per-commit <image>:<git-sha>.
# Then run ./publish to push, and ./run to launch.
#
# Auto-detects the container engine and PREFERS podman when both are present.
# Force one with  RUNTIME=docker ./build  (or RUNTIME=podman).
# Override the image name with  IMAGE=you/name ./build .

cd "$(dirname "$0")"

TARGET="${1:-all}"
case "$TARGET" in
    all|proxy|stats) ;;
    *) echo "usage: $0 [all|proxy|stats]" >&2; exit 2 ;;
esac

# Container engine: honor RUNTIME override, else prefer podman, then docker.
CE="${RUNTIME:-}"
if [ -z "$CE" ]; then
    if command -v podman >/dev/null 2>&1; then CE=podman
    elif command -v docker >/dev/null 2>&1; then CE=docker
    else echo "error: neither podman nor docker found on PATH" >&2; exit 1; fi
fi
command -v "$CE" >/dev/null 2>&1 || { echo "error: RUNTIME=$CE not found on PATH" >&2; exit 1; }

IMAGE="${IMAGE:-iphands/pkgcache}"
STATS_IMAGE="${STATS_IMAGE:-iphands/pkgcache-stats}"
REF="$(git rev-parse --short HEAD 2>/dev/null || echo dev)"
export DOCKER_BUILDKIT=1   # no-op under podman/buildah, enables it under docker

build_one() {  # $1=context dir  $2=image name
    if [ ! -f "$1/Dockerfile" ]; then
        echo "error: $1/Dockerfile does not exist yet -- nothing to build for '$1'" >&2
        return 1
    fi
    echo ">> [$CE] building ${2}:latest and ${2}:${REF}"
    "$CE" build -t "${2}:latest" -t "${2}:${REF}" "$1"
}

if [ "$TARGET" = all ] || [ "$TARGET" = proxy ]; then build_one proxy "$IMAGE"; fi
if [ "$TARGET" = all ] || [ "$TARGET" = stats ]; then build_one stats "$STATS_IMAGE"; fi
